# ---------------------------------------------------------------------------
# NihonPages environment variables. Copy to `.env` and fill in.
# DATABASE_URL is required — both local dev and prod run on Postgres, there's
# no in-memory/SQLite fallback. Everything else is optional and has a
# documented dev-mode fallback (see the comment above each block).
# ---------------------------------------------------------------------------

# Database (Prisma / Postgres) — get a free one from neon.tech or Vercel Postgres
DATABASE_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/nihonpages?sslmode=require"

# Auth.js (NextAuth)
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (one-time for Basic/Lifetime, subscriptions for Premium + Data Hub).
# Leave empty for a simulated checkout that still exercises the full flow.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Transactional email (Resend). Leave empty and sends land in the EmailLog
# table instead of a real inbox — fully inspectable without a provider.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="NihonPages <notifications@nihonpages.example.jp>"

# Protects /api/cron/digest (Vercel Cron hits it weekly per vercel.json).
# Set the same random string here and in Vercel's env vars.
CRON_SECRET=""

# S3-compatible object storage (photo uploads via signed URLs) — not yet wired
# up; the dashboard currently accepts pasted image URLs only.
S3_ENDPOINT=""
S3_REGION="ap-northeast-1"
S3_BUCKET="nihonpages-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Search (Meilisearch; falls back to Postgres full-text if unset) — not yet wired up.
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# Maps (optional — profile map uses a keyless embed by default)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Japan National Tax Agency corporate-number (法人番号) API — not yet wired up;
# the field is stored and displayed but not live-verified against the API.
HOUJIN_BANGOU_API_KEY=""

# Public site URL (used for canonical URLs, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL="https://nihonpages.example.jp"
