# ---------------------------------------------------------------------------
# NihonPages environment variables.
# Copy to `.env.local` and fill in. The app RUNS TODAY with none of these set
# (it uses the in-repo seed data layer); these are for the production backend.
# ---------------------------------------------------------------------------

# Database (Prisma / PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nihonpages?schema=public"

# Auth.js (NextAuth)
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (one-time for Basic/Lifetime, subscriptions for Premium + Data Hub)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# S3-compatible object storage (photo uploads via signed URLs)
S3_ENDPOINT=""
S3_REGION="ap-northeast-1"
S3_BUCKET="nihonpages-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Search (Meilisearch; falls back to Postgres full-text if unset)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# Transactional email (Resend or SES)
RESEND_API_KEY=""
EMAIL_FROM="NihonPages <hello@nihonpages.example.jp>"

# Maps (optional — profile map uses a keyless embed by default)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Japan National Tax Agency corporate-number (法人番号) API for verification
HOUJIN_BANGOU_API_KEY=""

# Public site URL (used for canonical URLs, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL="https://nihonpages.example.jp"
